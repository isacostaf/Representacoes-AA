<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scanner Representações - MD</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <main class="container">
      <section class="card">
        <header>
          <div>
            <h1>Scanner Representações - MD</h1>
            <p>Use o scanner para identificar representações entre datas e exportar os resultados rapidamente.</p>
          </div>
        </header>

        <div class="aviso-humano">
          Atenção: a análise automática pode conter erros. A verificação humana é indispensável antes de qualquer decisão.
        </div>

        <form method="post" action="/process">
          <div class="form-grid">
            <div class="field">
              <label for="dataInicial">Data inicial</label>
              <input id="dataInicial" name="dataInicial" type="date" value="<%= dataInicial %>" required />
            </div>

            <div class="field">
              <label for="dataFinal">Data final</label>
              <input id="dataFinal" name="dataFinal" type="date" value="<%= dataFinal %>" required />
            </div>

            <div class="field">
              <button class="primary" type="submit">Verificar resultados</button>
            </div>
          </div>
        </form>

        <% if (erro) { %>
          <div class="msg erro"><%= erro %></div>
        <% } %>

        <% if (aviso) { %>
          <div class="msg aviso"><%= aviso %></div>
        <% } %>

        <% if (runId) { %>
          <div class="actions">
            <a class="btn secondary" href="/download/csv/<%= runId %>">Baixar CSV</a>
            <a class="btn secondary" href="/download/zip/<%= runId %>/alta">Alta Chance</a>
            <a class="btn secondary" href="/download/zip/<%= runId %>/talvez">Talvez</a>
            <form action="/email/<%= runId %>" method="post">
              <button class="primary" type="submit">Enviar e-mail</button>
            </form>
          </div>
        <% } %>
      </section>

      <% if (rows && rows.length) { %>
        <section class="card">
          <h2>Resultados</h2>
          <p>Verde: cerca de 90% de chance de ser representação relevante. Amarelo: revisão manual recomendada.</p>

          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Documento</th>
                  <th>PDF</th>
                  <th>Classificação</th>
                  <th>Score Base</th>
                  <th>Score Representação</th>
                </tr>
              </thead>
              <tbody>
                <% rows.forEach((row) => { %>
                  <% const classe = row.Classificacao === "Alta chance" ? "alta" : row.Classificacao === "Talvez" ? "talvez" : ""; %>
                  <tr class="<%= classe %>">
                    <td><%= row.Documento %></td>
                    <td><a href="<%= row.PDF %>" target="_blank" rel="noopener noreferrer">Abrir PDF</a></td>
                    <td><%= row.Classificacao %></td>
                    <td><%= row["Score Base"] %></td>
                    <td><%= row["Score Representacao"] %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>
    </main>
  </body>
</html>
